[
    {
        "context": "Workspace",
        "bindings": {
            // "shift shift": "file_finder::Toggle"
        },
    },
    {
        "context": "Editor && vim_mode == insert",
        "bindings": {
            // "j k": "vim::NormalBefore"
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-s": "workspace::SaveAll",
        },
    },
    {
        "context": "Editor",
        "bindings": {
            "ctrl-alt-pageup": "editor::AddSelectionAbove",
            "ctrl-alt-pagedown": "editor::AddSelectionBelow",
            "ctrl-alt-l": "editor::Format",
            "ctrl-alt-down": null,
            "ctrl-shift-delete": "editor::DeleteLine",

        },
    },
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "enter": "project_panel::OpenPermanent",
        },
    },
    {
        "context": "Editor",
        "bindings": {
            "ctrl-alt-down": null
        }
    },
    {
        "context": "Editor",
        "bindings": {
            "ctrl-alt-up": null
        }
    }
]
